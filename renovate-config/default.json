{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for wpfleger96 repos",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "platformAutomerge": true,
  "automergeType": "pr",
  "schedule": ["* * * * 1,4"],
  "minimumReleaseAge": "1 week",
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* * * * 1,4"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "automerge": false,
      "groupName": "github-actions",
      "groupSlug": "github-actions"
    },
    {
      "matchManagers": ["pyenv", "nvm", "nodenv", "asdf", "mise"],
      "automerge": false,
      "groupName": "language runtimes",
      "groupSlug": "language-runtimes"
    },
    {
      "matchDatasources": ["python-version", "node-version"],
      "automerge": false
    },
    {
      "matchDepNames": ["python", "node", "ruby", "golang", "openjdk", "eclipse-temurin"],
      "automerge": false
    }
  ]
}
